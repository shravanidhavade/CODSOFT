<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Poppins', sans-serif;
    background-color: #f0f4ff;
  }

  /* HEADER */
  header {
    background-color: #4f46e5;
    color: white;
    text-align: center;
    padding: 40px 20px 30px;
  }

  header img {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    border: 4px solid white;
    margin-bottom: 12px;
  }

  header h1 {
    font-size: 28px;
    font-weight: 700;
  }

  header p {
    font-size: 14px;
    margin-top: 6px;
    opacity: 0.85;
  }

  /* MAIN */
  main {
    max-width: 700px;
    margin: 30px auto;
    padding: 0 16px 40px;
  }

  /* SECTION BOX */
  .box {
    background: white;
    border-radius: 12px;
    padding: 24px 22px;
    margin-bottom: 20px;
    border-left: 5px solid #4f46e5;
    box-shadow: 0 3px 10px rgba(0,0,0,0.08);
  }

  .box h2 {
    font-size: 18px;
    color: #4f46e5;
    margin-bottom: 12px;
  }

  .box p {
    font-size: 14px;
    color: #444;
    line-height: 1.8;
  }

  /* SKILLS */
  .skills-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .skill {
    background: #e0e7ff;
    color: #3730a3;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
  }

  /* PROJECTS */
  .project {
    background: #f5f3ff;
    border: 1.5px solid #c4b5fd;
    border-radius: 10px;
    padding: 14px 16px;
    margin-top: 12px;
  }

  .project h3 {
    font-size: 15px;
    color: #3730a3;
    margin-bottom: 5px;
  }

  .project p {
    font-size: 13px;
    color: #555;
    line-height: 1.7;
  }

  /* BUTTON */
  .btn {
    display: inline-block;
    margin-top: 10px;
    padding: 10px 22px;
    background-color: #4f46e5;
    color: white;
    border-radius: 8px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
  }

  .btn:hover {
    background-color: #4338ca;
  }

  /* CONTACT */
  .contact-item {
    font-size: 14px;
    color: #444;
    margin-top: 8px;
  }

  /* FOOTER */
  footer {
    text-align: center;
    background-color: #4f46e5;
    color: white;
    padding: 16px;
    font-size: 13px;
  }
</style>
</head>

